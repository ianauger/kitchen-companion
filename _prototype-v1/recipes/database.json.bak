    {
      "recipe_uid": "bb-chicken-burgers-002",
      "recipe_name": "Juicy Ground Chicken Burgers",
      "base": "Burger Buns",
      "protein": "Ground chicken",
      "pivot": "American Classic",
      "mapping_type": "Special Case",
      "servings": 4,
      "ingredients": [
        {"item": "Ground chicken", "quantity": "1 lb"},
        {"item": "Yellow onion, minced", "quantity": "1/4 cup"},
        {"item": "Panko breadcrumbs", "quantity": "1/4 cup"},
        {"item": "Mayonnaise", "quantity": "2 tbsp"},
        {"item": "Fresh parsley, minced", "quantity": "1 tbsp"},
        {"item": "Worcestershire sauce", "quantity": "1 tsp"},
        {"item": "Salt", "quantity": "1/2 tsp"},
        {"item": "Garlic powder", "quantity": "1/2 tsp"},
        {"item": "Black pepper", "quantity": "1/4 tsp"},
        {"item": "Hamburger buns", "quantity": "4"},
        {"item": "Cooking oil", "quantity": "1 tbsp"}
      ],
      "steps": [
        "Heat oil in skillet, sauté onion 2-3 min until soft. Remove from heat.",
        "Combine ground chicken, sautéed onion, panko, mayo, parsley, Worcestershire, salt, garlic powder, and pepper. Mix just until combined.",
        "Divide into 4 portions (4 oz each). Shape into patties, press thumb indent in center of each.",
        "Grill or pan-sear 4-5 min per side until internal temp reaches 165°F.",
        "Toast buns on grill 1-2 min. Let burgers rest 3-4 min before serving.",
        "Top with lettuce, tomato, pickles, red onion as desired."
      ],
      "estimated_cost_per_serving": 1.59,
      "calories_est": 437,
      "protein_g": 27,
      "rating": 5.0,
      "rating_count": 4,
      "source_url": "https://www.budgetbytes.com/chicken-burger/",
      "chef_notes": "Mayo keeps lean chicken juicy - don't skip it! Don't overmix or patties get tough. Freeze raw patties up to 3 months.",
      "added_date": "2026-04-11"
    },
